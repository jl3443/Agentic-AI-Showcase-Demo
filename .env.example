# ============================================
# AI AP Operations Manager - Environment Config
# ============================================

# Database
DATABASE_URL=postgresql://ap_user:ap_password_dev@localhost:5432/ap_operations

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Object Storage (MinIO / S3)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=ap-invoices

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# AI / LLM
LLM_API_KEY=your-claude-api-key-here
LLM_MODEL=claude-sonnet-4-6

# OCR (V1 - Azure Document Intelligence)
OCR_ENDPOINT=mock
OCR_API_KEY=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-this-to-a-random-secret-in-production
