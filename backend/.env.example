# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://ap_user:ap_password_dev@localhost:5432/ap_operations

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# S3 / MinIO (matches docker-compose.yml)
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=ap-invoices
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123

# LLM / AI
LLM_API_KEY=your-anthropic-api-key-here
LLM_MODEL=claude-sonnet-4-20250514

# OCR (mock in MVP)
OCR_ENDPOINT=http://localhost:8080/ocr

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
